# Copy this file to .env and fill in your keys
# cp .env.example .env

# Tavily web search (free, no card) — https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# TMDB movie search (free, no card) — https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Last.fm music search (free, no card) — https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
